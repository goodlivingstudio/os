# ─── Required ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Vercel KV (caching, article store, curation) ───────────────────────────
KV_REST_API_URL=https://your-kv.upstash.io
KV_REST_API_TOKEN=your-token

# ─── Instance Selection (default: dispatch) ──────────────────────────────────
# Valid values: dispatch | explore | lilly-direct
# NEXT_PUBLIC_INSTANCE=explore
# NEXT_PUBLIC_INSTANCE=lilly-direct

# ─── Optional Services ──────────────────────────────────────────────────────
ARENA_ACCESS_TOKEN=your-arena-token
EXA_API_KEY=your-exa-key
REPLICATE_API_TOKEN=your-replicate-token

# ─── Gallery Collection APIs ─────────────────────────────────────────────────
UNSPLASH_ACCESS_KEY=your-unsplash-key
FLICKR_API_KEY=your-flickr-key

# ─── API Protection (required in production) ────────────────────────────────
# Protects destructive endpoints (purge, curate, memory delete, usage).
# When unset, all requests pass through (local dev). When set, requires
# Authorization: Bearer <API_SECRET> header.
# API_SECRET=your-api-secret

# ─── Vercel Cron Auth (required in production) ──────────────────────────────
# Protects /api/gallery/cycle. In production (Vercel), the endpoint will
# refuse to run if this is not set.
# CRON_SECRET=your-secret

# ─── GitHub Actions Secrets ──────────────────────────────────────────────────
# Required to activate the daily-scrape workflow:
#   ARENA_ACCESS_TOKEN (same as above)
#   ANTHROPIC_API_KEY  (same as above)
