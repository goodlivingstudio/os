{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dispatch",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["/usr/local/bin/npm", "run", "dev", "--", "-p", "3001"],
      "port": 3001,
      "env": {
        "PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"
      }
    },
    {
      "name": "explore",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["/usr/local/bin/npm", "run", "dev", "--", "-p", "3002"],
      "port": 3002,
      "env": {
        "PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin",
        "NEXT_PUBLIC_INSTANCE": "explore"
      }
    }
  ]
}
