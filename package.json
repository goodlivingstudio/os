{
  "name": "dispatch",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "dev:dispatch": "next dev -p 3001",
    "dev:explore": "NEXT_PUBLIC_INSTANCE=explore next dev -p 3002",
    "build": "next build",
    "build:explore": "NEXT_PUBLIC_INSTANCE=explore next build",
    "start": "next start",
    "lint": "eslint",
    "scrape": "npx tsx scripts/gallery-scraper.ts",
    "scrape:dispatch": "npx tsx scripts/gallery-scraper.ts --instance=dispatch",
    "scrape:explore": "npx tsx scripts/gallery-scraper.ts --instance=explore",
    "scrape:explore:taste": "npx tsx scripts/gallery-scraper.ts --instance=explore --taste",
    "scrape:explore:ugc": "npx tsx scripts/gallery-scraper.ts --instance=explore --ugc --taste",
    "collect:explore": "npx tsx scripts/gallery-collector.ts --instance=explore",
    "collect:explore:ugc": "npx tsx scripts/gallery-collector.ts --instance=explore --ugc"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@vercel/kv": "^3.0.0",
    "colorthief": "^3.3.1",
    "docx": "^9.6.1",
    "file-saver": "^2.0.5",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "playwright": "^1.59.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
