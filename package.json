{
  "name": "os",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "dev:dispatch": "next dev -p 3001",
    "dev:explore": "NEXT_PUBLIC_INSTANCE=explore next dev -p 3002",
    "dev:lilly-direct": "NEXT_PUBLIC_INSTANCE=lilly-direct next dev -p 3003",
    "build": "next build",
    "build:explore": "NEXT_PUBLIC_INSTANCE=explore next build",
    "build:lilly-direct": "NEXT_PUBLIC_INSTANCE=lilly-direct next build",
    "start": "next start",
    "lint": "eslint",
    "scrape": "npx tsx scripts/gallery-scraper.ts",
    "scrape:dispatch": "npx tsx scripts/gallery-scraper.ts --instance=dispatch",
    "scrape:explore": "npx tsx scripts/gallery-scraper.ts --instance=explore",
    "scrape:explore:taste": "npx tsx scripts/gallery-scraper.ts --instance=explore --taste",
    "collect:explore": "npx tsx scripts/gallery-collector.ts --instance=explore",
    "docs:check": "node scripts/check-doc-links.mjs",
    "docs:export": "bash scripts/regenerate-docs-exports.sh",
    "docs:terms": "bash scripts/check-stale-terms.sh",
    "docs:verify": "npm run docs:export && npm run docs:check && npm run docs:terms",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.87.0",
    "@base-ui/react": "^1.3.0",
    "@vercel/kv": "^3.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "colorthief": "^3.3.1",
    "docx": "^9.6.1",
    "file-saver": "^2.0.5",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "playwright": "^1.59.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "recharts": "^3.8.0",
    "shadcn": "^4.2.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "prettier": "^3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
