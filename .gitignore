# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# scratch / session-local working artifacts
# These are reference documents the operator keeps open while working across
# multiple surfaces (Claude.ai, editor, browser). Intentionally uncommitted —
# they are working notes, not doctrine. Delete after the relevant session ends.
.claude/PHASE-PLAN.md
.claude/SCRATCH-*.md
